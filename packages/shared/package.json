{
  "name": "@wpc/shared",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./types/game.types.ts",
      "import": "./dist/types/game.types.js",
      "default": "./dist/types/game.types.js"
    },
    "./types/socket-events": {
      "types": "./types/socket-events.ts",
      "import": "./dist/types/socket-events.js",
      "default": "./dist/types/socket-events.js"
    },
    "./utils": {
      "types": "./utils/scoring.ts",
      "import": "./dist/utils/scoring.js",
      "default": "./dist/utils/scoring.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
